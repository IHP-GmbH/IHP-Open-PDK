        # EMWIND / DEEPCO / MIM
        "emwind_drw" => emwind_drw,
        "emwind_opc" => emwind_opc,
        "deepco_drw" => deepco_drw,
        "mim_drw"    => mim_drw,

        # SUBSTRATE / IC / VIA3
        "substrate_drw" => substrate_drw,
