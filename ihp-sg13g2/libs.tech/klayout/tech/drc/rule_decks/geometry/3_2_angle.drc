        "polyres_drw"     => polyres_drw,
        "polyres_pin"     => polyres_pin,
        "vmim_drw"        => vmim_drw,
        "nbulaycut_drw"   => nbulaycut_drw,
        "antmetal1_drw"   => antmetal1_drw,
        "topvia2_drw"     => topvia2_drw,
        "topmetal2_drw"   => topmetal2_drw,
        "topmetal2_pin"   => topmetal2_pin,
        "topmetal2_mask"  => topmetal2_mask,
        "topmetal2_filler" => topmetal2_filler,
        "topmetal2_nofill" => topmetal2_nofill,
        "topmetal2_slit"   => topmetal2_slit,
        "topmetal2_noqrc"  => topmetal2_noqrc,
        "topmetal2_res"    => topmetal2_res,
        "topmetal2_iprobe" => topmetal2_iprobe,
        "topmetal2_diffprb" => topmetal2_diffprb,
        "snsring_drw"     => snsring_drw,
        "sensor_drw"      => sensor_drw,
        "snsarms_drw"     => snsarms_drw,
        "snscmosvia_drw"  => snscmosvia_drw,
        "colwind_drw"     => colwind_drw,
        "flm_drw"         => flm_drw,
        "hafniumox_drw"   => hafniumox_drw,
        "memvia_drw"      => memvia_drw,
        "thinfilmres_drw" => thinfilmres_drw,
        "rfmem_drw"       => rfmem_drw,
        "snsbotvia_drw"   => snsbotvia_drw,
        "snstopvia_drw"   => snstopvia_drw,
        "deepvia_drw"     => deepvia_drw,
        "fgetch_drw"      => fgetch_drw,
        "ctrgat_drw"      => ctrgat_drw,
        "fgimp_drw"       => fgimp_drw,
        "emwihv_drw"      => emwihv_drw,
        "lbe_drw"         => lbe_drw,
        "alcustop_drw"    => alcustop_drw
    }.freeze

    def non_circular_polys(layer_polys, circle_cache)
        return nil if layer_polys.nil?

        circles = circle_cache[layer_polys.object_id]
        unless circles
            circles = get_circle(layer_polys)
            circle_cache[layer_polys.object_id] = circles
        end

        layer_polys.not(circles)
    end

    def acute_angle_check(layer_polys, base_name, acute_limit_deg, circle_cache)
        return if layer_polys.nil?

        # Polygon `with_angle` returns corners in the specified angle interval.
        # Here we flag corners with angle < 87 degree.
        non_circular = non_circular_polys(layer_polys, circle_cache)
        acute_corners = non_circular.with_angle(0.0, acute_limit_deg)
        acute_corners.output(
            "#{base_name}_Acute",
            "3.2 #{base_name}_Acute: acute corner angle below #{acute_limit_deg} degree is not allowed."
        )
    end

    def orthogonal_edge_angle_check(layer_polys, base_name, circle_cache)
        return if layer_polys.nil?

        # Allowed edge angles: 0 and 90 degree (absolute mode).
        non_circular = non_circular_polys(layer_polys, circle_cache)
        invalid_edges = non_circular.edges.without_angle(0, absolute).without_angle(90, absolute)
        invalid_edges.output(
            "#{base_name}_Angle90",
            "3.2 #{base_name}_Angle90: only orthogonal edges (0/90 degree) are allowed."
        )
    end

    def orthogonal_45_edge_angle_check(layer_polys, base_name, circle_cache)
        return if layer_polys.nil?

        # Allowed edge angles: 0, 45 and 90 degree (absolute mode).
        non_circular = non_circular_polys(layer_polys, circle_cache)
        invalid_edges = non_circular.edges.without_angle(0, absolute).without_angle(45, absolute).without_angle(90, absolute)
        invalid_edges.output(
            "#{base_name}_Angle45",
            "3.2 #{base_name}_Angle45: only 0/45/90 degree edges are allowed."
        )
    end

    circle_cache = {}

    # 1) Global acute-angle checks.
    ACUTE_SCOPE_LAYERS.each do |name, layer_polys|
        logger.info("Executing rule #{name}_Acute")
        acute_angle_check(layer_polys, name, ACUTE_LIMIT_DEG, circle_cache)
    end

    # 2) Edge-angle restrictions for orthogonal-only layers.
    ORTHO_ONLY_LAYERS.each do |name, layer_polys|
        logger.info("Executing rule #{name}_Angle90")
        orthogonal_edge_angle_check(layer_polys, name, circle_cache)
    end

    # 3) Edge-angle restrictions for 0/45/90 layers.
    ORTHO_45_LAYERS.each do |name, layer_polys|
        logger.info("Executing rule #{name}_Angle45")
        orthogonal_45_edge_angle_check(layer_polys, name, circle_cache)
    end
end

