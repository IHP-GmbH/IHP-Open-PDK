if TABLES.include?('angle') || ANGLE
    #================================================
    #--------------- ANGLE CHECKS -------------------
    #================================================
    #
    logger.info('Starting 3.2. angle table')

    # Rule intent:
    # 1) Acute corners < 87 degree are not allowed.
    # 2) Specific layers allow only orthogonal edge angles (0/90).
    # 3) Specific layers allow only 0/45/90 edge angles.
    # NOTE (per PDK note):
    # Offgrid and angle checks are NOT applied on:
    # DigiBnd, DigiSub, dfpad, EdgeSeal, HeatRes, HeatTrans, IND, NoDRC,
    # NoMetFiller, NoRCX, RadHard, Recog, RES, Scribe, SRAM, TEXT.
    #
    # Circular polygons are excluded from geometry checks by design.

    ACUTE_LIMIT_DEG = 87.0

    # Layers explicitly constrained to orthogonal edges only.
    ORTHO_ONLY_LAYERS = {
        "cont_drw"    => cont_drw,
        "via1_drw"    => via1_drw,
        "via2_drw"    => via2_drw,
        "via3_drw"    => via3_drw,
        "via4_drw"    => via4_drw,
        "vmim_drw"    => vmim_drw,
        "topvia1_drw" => topvia1_drw,
        "topvia2_drw" => topvia2_drw
    }.freeze

    # Layers explicitly constrained to orthogonal + 45-degree edges.
    ORTHO_45_LAYERS = {
        "gatpoly_drw"   => gatpoly_drw,
        "activ_drw"     => activ_drw,
        "metal1_drw"    => metal1_drw,
        "metal2_drw"    => metal2_drw,
        "metal3_drw"    => metal3_drw,
        "metal4_drw"    => metal4_drw,
        "metal5_drw"    => metal5_drw,
        "topmetal1_drw" => topmetal1_drw,
        "topmetal2_drw" => topmetal2_drw
    }.freeze

